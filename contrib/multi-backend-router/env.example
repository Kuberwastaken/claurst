# Copy this file to ~/.claude/litellm/env and fill in only the values you need.
# The start/status scripts auto-load ~/.claude/litellm/env and ~/.claude/litellm/env.local.

# Cheap cloud fallbacks / cloud mode
export DEEPSEEK_API_KEY=""
export TOGETHER_API_KEY=""
export GEMINI_API_KEY=""
export GROQ_API_KEY=""

# Direct Moonshot / Kimi mode for Claude Code
export MOONSHOT_API_KEY=""
# export KIMI_API_KEY=""
# export MOONSHOT_BASE_URL="https://api.moonshot.ai/anthropic"
# export MOONSHOT_MODEL="kimi-k2.5"
# export MOONSHOT_HAIKU_MODEL="kimi-k2.5"
# export MOONSHOT_SONNET_MODEL="kimi-k2.5"
# export MOONSHOT_OPUS_MODEL="kimi-k2-thinking"
# export MOONSHOT_SUBAGENT_MODEL="kimi-k2.5"
# export MOONSHOT_ENABLE_TOOL_SEARCH="false"

# Optional local overrides
# Wrapper auth token used for local LiteLLM routing. Any value works on localhost.
# export CLAUDE_PROXY_API_KEY="sk-litellm"
# export LITELLM_HOST="127.0.0.1"
# export LITELLM_PORT="4000"
# export OLLAMA_HOST="127.0.0.1"
# export OLLAMA_PORT="11434"
# export OLLAMA_CONTEXT_LENGTH="32768"

# llama.cpp mode
# You only need to override these if you want a different port/model.
# export LLAMACPP_PORT="8080"
# export LLAMACPP_FALLBACK_PORT="18080"
# export LLAMACPP_CTX_SIZE="65536"
# export LLAMACPP_NGL="99"
# export LLAMACPP_ALIAS="qwen3-coder-30b"
# export LLAMACPP_API_KEY="sk-dummy"
# export LLAMACPP_MODEL="${HOME}/.ollama/models/blobs/<your-qwen3-coder-30b-gguf-blob>"

# Binary overrides if you installed tools somewhere else
# export OLLAMA_BIN="/opt/homebrew/bin/ollama"
# export LLAMACPP_BIN="/opt/homebrew/bin/llama-server"
# export LITELLM_BIN="$(command -v litellm)"
